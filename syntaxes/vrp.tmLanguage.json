{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Huawei VRP",
    "fileTypes": [
        "vrp",
        "cfg"
    ],
    "patterns": [
        {
            "include": "#header"
        },
        {
            "include": "#comment"
        },
        {
            "include": "#dangerous"
        },
        {
            "include": "#section_bgp"
        },
        {
            "include": "#section_ospf"
        },
        {
            "include": "#section_ospfv3"
        },
        {
            "include": "#section_aaa"
        },
        {
            "include": "#section_interface"
        },
        {
            "include": "#route_policy"
        },
        {
            "include": "#ip_prefix"
        },
        {
            "include": "#ipv6_prefix"
        },
        {
            "include": "#static_route"
        },
        {
            "include": "#static_route_v6"
        },
        {
            "include": "#ssh_server"
        },
        {
            "include": "#snmp_agent"
        },
        {
            "include": "#global_keywords"
        },
        {
            "include": "#permit_deny_action"
        },
        {
            "include": "#undo_keyword"
        },
        {
            "include": "#ipv6_address"
        },
        {
            "include": "#ipv4_address"
        },
        {
            "include": "#mac_address"
        },
        {
            "include": "#number_constant"
        },
        {
            "include": "#string_quoted"
        }
    ],
    "repository": {
        "header": {
            "comment": "Prompt header line like <BNG-FAST_TELECOM-VS-BGP>dis cu or version banners",
            "patterns": [
                {
                    "name": "markup.italic.vrp",
                    "match": "^(<[^>]+>.*|\\[.*\\])$"
                },
                {
                    "name": "comment.block.documentation.vrp",
                    "match": "^!(Software Version|Last configuration|kms_feature).*$"
                }
            ]
        },
        "comment": {
            "comment": "Section separator # and inline comments",
            "patterns": [
                {
                    "name": "comment.line.number-sign.vrp",
                    "match": "^\\s*#(\\s.*)?$"
                }
            ]
        },
        "dangerous": {
            "comment": "Dangerous / destructive commands",
            "patterns": [
                {
                    "name": "invalid.illegal.dangerous.vrp",
                    "match": "\\b(reboot|reset|delete|format|shutdown|commit(?!\\s+peer)|^error|^Error|^Warning|^warning)\\b"
                },
                {
                    "name": "invalid.illegal.return.vrp",
                    "match": "^return\\s*$"
                }
            ]
        },
        "section_bgp": {
            "comment": "BGP section keywords",
            "patterns": [
                {
                    "name": "entity.name.section.bgp.vrp",
                    "match": "^bgp\\s+\\d+"
                },
                {
                    "name": "keyword.control.bgp.family.vrp",
                    "match": "^\\s+(ipv4-family|ipv6-family)\\s+(unicast|multicast|vpnv4|vpnv6|labeled-unicast)\\b"
                },
                {
                    "name": "keyword.control.bgp.group.vrp",
                    "match": "^\\s+group\\s+\\S+\\s+(external|internal|ibgp|ebgp)\\b"
                },
                {
                    "name": "keyword.control.bgp.peer.vrp",
                    "match": "^\\s+peer\\s+"
                },
                {
                    "name": "entity.name.tag.bgp-attr.vrp",
                    "match": "\\b(as-number|route-policy|group|fake-as|enable|description|next-hop-local|next-hop-invariable|reflect-client|keep-all-routes|allow-as-loop|graceful-restart|timer|connect-retry|hold|password|update-source|ebgp-max-hop|log-change|prefix-limit|advertise-community|advertise-ext-community|default-route-advertise|import-route|synchronization|preference|router-id|check-first-as|private-4-byte-as|undo synchronization|undo check-first-as)\\b"
                },
                {
                    "name": "support.function.bgp-route.vrp",
                    "match": "\\b(import-route|import-route direct|import-route static|import-route ospf|import-route isis|import-route rip|import-route connected)\\b"
                },
                {
                    "name": "support.type.bgp.vrp",
                    "match": "\\b(local-preference|med|weight|as-path|community|ext-community|origin|atomic-aggregate|aggregator|originator-id|cluster-list|large-community)\\b"
                }
            ]
        },
        "section_ospf": {
            "comment": "OSPF section",
            "patterns": [
                {
                    "name": "entity.name.section.ospf.vrp",
                    "match": "^ospf\\s+\\d+(\\s+router-id\\s+\\S+)?\\s*$"
                },
                {
                    "name": "keyword.control.ospf.vrp",
                    "match": "^\\s+(area|network|opaque-capability|nssa|stub|authentication-mode|import-route|default-cost|timer|bandwidth-reference|lsdb-overflow-limit|preference|silent-interface|p2p-peer|maximum\\s+load-balancing)\\b"
                },
                {
                    "name": "keyword.control.ospf-network.vrp",
                    "match": "^\\s+network\\s+"
                },
                {
                    "name": "entity.other.ospf-area.vrp",
                    "match": "\\barea\\s+\\d+\\.\\d+\\.\\d+\\.\\d+\\b"
                }
            ]
        },
        "section_ospfv3": {
            "comment": "OSPFv3 section",
            "patterns": [
                {
                    "name": "entity.name.section.ospfv3.vrp",
                    "match": "^ospfv3\\s+\\d+\\s*$"
                },
                {
                    "name": "keyword.control.ospfv3.vrp",
                    "match": "^\\s+(router-id|area|import-route|preference)\\b"
                },
                {
                    "name": "keyword.control.ospfv3-iface.vrp",
                    "match": "^\\s+(ospfv3\\s+\\d+\\s+area|ospfv3\\s+network-type|ospfv3\\s+mtu-ignore|ospf\\s+network-type|ospf\\s+enable)\\b"
                }
            ]
        },
        "section_aaa": {
            "comment": "AAA and authentication section",
            "patterns": [
                {
                    "name": "entity.name.section.aaa.vrp",
                    "match": "^aaa\\s*$"
                },
                {
                    "name": "keyword.control.aaa.vrp",
                    "match": "^\\s+(authentication-scheme|authorization-scheme|accounting-scheme|domain|local-user|local-aaa-server|radius-server|ip-pool|ipv6-pool|dns|gateway|section|prefix|delegation|user-password|rule|forbidden|authening|nas|accounting-start-delay|qos|dns-server)\\b"
                },
                {
                    "name": "support.function.aaa.vrp",
                    "match": "\\b(authentication-mode|accounting-mode|accounting|shared-key|source-ip|service-type|level|state|block|fail-times|interval|password|irreversible-cipher|primary-ip|second-ip|primary-ipv6|second-ipv6|online|user-group|expire|password-force-change|word|radius-no-response|logic-sysname|user-type|rate-limit-mode|inbound|outbound|shared-key-cipher|retransmit|timeout|accounting-start-packet|accounting-stop-packet|accounting-interim-packet|attribute|translate|user-name|trust-server-request|send|after-ppp|force)\\b"
                }
            ]
        },
        "section_interface": {
            "comment": "Interface declaration and sub-interface params",
            "patterns": [
                {
                    "name": "entity.name.function.interface.vrp",
                    "match": "^interface\\s+\\S+"
                },
                {
                    "name": "keyword.control.interface.vrp",
                    "match": "^\\s+(vlan-type|description|ipv6\\s+enable|ip\\s+address|ipv6\\s+address|statistic\\s+enable|mtu|bandwidth|dampening|loopback|portswitch|undo\\s+portswitch|negotiation\\s+auto|speed|duplex|flow-control|trust\\s+upstream|qos|service-template|pppoe|pppoe-server|nat|user-vlan|bas|access-type|ipv6\\s+nd\\s+ra|ppp\\s+authentication-mode|mode|eth-trunk|dcn|ip\\s+binding\\s+vpn-instance|ve-group|mac-address|port|link-type|trunk|allow-pass|ip\\s+urpf|ipv6\\s+urpf|tcp\\s+adjust-mss|port-mode|car)\\b"
                },
                {
                    "name": "keyword.other.vlan-type.vrp",
                    "match": "\\bvlan-type\\s+(dot1q|qinq)\\s+\\d+"
                },
                {
                    "name": "support.class.interface-type.vrp",
                    "match": "\\b(GigabitEthernet|10GE|40GE|100GE|XGigabitEthernet|Eth-Trunk|LoopBack|Tunnel|Virtual-Ethernet|NULL|Vlanif|MEth|FlexE)\\b"
                },
                {
                    "name": "keyword.other.ipv6-addr.iface.vrp",
                    "match": "\\bipv6\\s+address\\s+auto\\s+link-local\\b"
                }
            ]
        },
        "route_policy": {
            "comment": "route-policy blocks",
            "patterns": [
                {
                    "match": "^(route-policy)\\s+(\\S+)\\s+(permit)\\s+(node)\\s+(\\d+)",
                    "captures": {
                        "1": {
                            "name": "entity.name.tag.route-policy.vrp"
                        },
                        "2": {
                            "name": "entity.name.tag.route-policy.vrp"
                        },
                        "3": {
                            "name": "markup.inserted.permit.vrp"
                        },
                        "4": {
                            "name": "entity.name.tag.route-policy.vrp"
                        },
                        "5": {
                            "name": "constant.numeric.integer.vrp"
                        }
                    }
                },
                {
                    "match": "^(route-policy)\\s+(\\S+)\\s+(deny)\\s+(node)\\s+(\\d+)",
                    "captures": {
                        "1": {
                            "name": "entity.name.tag.route-policy.vrp"
                        },
                        "2": {
                            "name": "entity.name.tag.route-policy.vrp"
                        },
                        "3": {
                            "name": "invalid.illegal.deny.vrp"
                        },
                        "4": {
                            "name": "entity.name.tag.route-policy.vrp"
                        },
                        "5": {
                            "name": "constant.numeric.integer.vrp"
                        }
                    }
                },
                {
                    "name": "keyword.control.route-policy-clause.vrp",
                    "match": "^\\s+(if-match|apply)\\s+"
                },
                {
                    "name": "support.function.if-match.vrp",
                    "match": "\\b(ip-prefix|ipv6\\s+address\\s+prefix-list|community|ext-community|as-path-filter|cost|interface|metric|origin|tag|large-community|mpls-label)\\b"
                },
                {
                    "name": "support.function.apply.vrp",
                    "match": "\\b(local-preference|med|weight|community|as-path|origin|cost|tag|mpls-label|next-hop|ext-community|large-community|preferred-value|additive)\\b"
                }
            ]
        },
        "ip_prefix": {
            "comment": "ip ip-prefix statements",
            "patterns": [
                {
                    "name": "entity.name.class.ip-prefix.vrp",
                    "match": "^ip\\s+ip-prefix\\s+\\S+\\s+index\\s+\\d+\\s+"
                },
                {
                    "name": "keyword.operator.prefix-range.vrp",
                    "match": "\\b(greater-equal|less-equal)\\b"
                }
            ]
        },
        "ipv6_prefix": {
            "comment": "ip ipv6-prefix statements",
            "patterns": [
                {
                    "name": "entity.name.class.ipv6-prefix.vrp",
                    "match": "^ip\\s+ipv6-prefix\\s+\\S+\\s+index\\s+\\d+\\s+"
                },
                {
                    "name": "keyword.operator.prefix-range.vrp",
                    "match": "\\b(greater-equal|less-equal)\\b"
                }
            ]
        },
        "static_route": {
            "comment": "IPv4 static routes",
            "patterns": [
                {
                    "name": "keyword.control.static-route.vrp",
                    "match": "^ip\\s+route-static\\b"
                }
            ]
        },
        "static_route_v6": {
            "comment": "IPv6 static routes",
            "patterns": [
                {
                    "name": "keyword.control.static-route-v6.vrp",
                    "match": "^ipv6\\s+route-static\\b"
                }
            ]
        },
        "ssh_server": {
            "comment": "SSH server and client hardening",
            "patterns": [
                {
                    "name": "keyword.control.ssh.vrp",
                    "match": "^(ssh\\s+server|ssh\\s+client|ssh\\s+authorization-type|ssh\\s+user|user-interface|stelnet\\s+server|snetconf\\s+server)\\b"
                },
                {
                    "name": "support.constant.ssh-algo.vrp",
                    "match": "\\b(aes256_gcm|aes128_gcm|aes256_ctr|aes192_ctr|aes128_ctr|sha2_512|sha2_256|sha1|dh_group_exchange_sha256|dh_group_exchange_sha1|dh_group14_sha1|rsa_sha2_256|rsa_sha2_512|ecdh_sha2_nistp256|ecdh_sha2_nistp384|ecdh_sha2_nistp521|ecc|rsa)\\b"
                },
                {
                    "name": "support.function.ssh-param.vrp",
                    "match": "\\b(cipher|hmac|key-exchange|publickey|rsa-key|dh-exchange|min-length|min-len|authentication-type|server-source|authorization-type|maximum-vty|ip-block)\\b"
                }
            ]
        },
        "snmp_agent": {
            "comment": "SNMP agent configuration",
            "patterns": [
                {
                    "name": "keyword.control.snmp.vrp",
                    "match": "^snmp-agent\\b"
                },
                {
                    "name": "support.function.snmp.vrp",
                    "match": "\\b(local-engineid|sys-info|version|community|group|usm-user|v1|v2c|v3|protocol\\s+source-status|proxy\\s+protocol|trap\\s+source|target-host)\\b"
                }
            ]
        },
        "global_keywords": {
            "comment": "Top-level global commands",
            "patterns": [
                {
                    "name": "keyword.control.global.vrp",
                    "match": "^(sysname|ntp-service|dhcp|icmp|telnet|service-template|local-aaa-server|user-interface|FTP|ftp|switch\\s+virtual-system|system-view|quit|commit|set|ssl\\s+policy|ssl\\s+cipher-suite-list|diffserv\\s+domain|soc|mpls|dot1x-template|security\\s+password|license|warranty|ccc|dcn|lldp|web-auth-server|netconf|pki\\s+domain|admin|virtual-system|l2tp-group|clock|as-notation|cpu-defend|dhcpv6|radius|radius-server)\\b"
                },
                {
                    "name": "entity.name.section.other.vrp",
                    "match": "^(vlan|acl|traffic-classifier|traffic-behavior|traffic|qos|mpls|ldp|rsvp|isis|rip|evpn|vpls|vxlan|tunnel-policy|ip-pool|ipv6-pool|ip\\s+vpn-instance|ip\\s+dcn\\s+vpn-instance|radius-server\\s+template|domain|radius-server\\s+group|ipv6\\s+prefix|cpu-defend\\s+policy|slot|traffic\\s+policy)\\b"
                }
            ]
        },
        "permit_deny_action": {
            "comment": "permit / deny as standalone action words",
            "patterns": [
                {
                    "name": "markup.inserted.permit.vrp",
                    "match": "\\b(permit|undo\\s+shutdown)\\b"
                },
                {
                    "name": "invalid.illegal.deny.vrp",
                    "match": "\\bdeny\\b"
                }
            ]
        },
        "undo_keyword": {
            "comment": "undo prefix — marks negation of a command",
            "patterns": [
                {
                    "name": "invalid.deprecated.undo.vrp",
                    "match": "^\\s*undo\\b"
                }
            ]
        },
        "ipv6_address": {
            "comment": "IPv6 addresses and prefixes (including :: shorthand)",
            "patterns": [
                {
                    "name": "constant.numeric.ipv6.vrp",
                    "match": "\\b(?:[0-9a-fA-F]{1,4}:){1,7}[0-9a-fA-F]{1,4}\\b|\\b(?:[0-9a-fA-F]{1,4}:){1,6}:[0-9a-fA-F]{1,4}\\b|\\b(?:[0-9a-fA-F]{1,4}:){1,5}(?::[0-9a-fA-F]{1,4}){1,2}\\b|\\b::[0-9a-fA-F]{1,4}\\b|\\b(?:[0-9a-fA-F]{1,4}:){1,7}:\\b|^::$"
                },
                {
                    "name": "constant.numeric.ipv6-prefix-len.vrp",
                    "match": "/\\d{1,3}\\b"
                }
            ]
        },
        "ipv4_address": {
            "comment": "IPv4 address and subnet mask",
            "patterns": [
                {
                    "name": "constant.numeric.ipv4.vrp",
                    "match": "\\b(?:(?:25[0-5]|2[0-4]\\d|[01]?\\d\\d?)\\.){3}(?:25[0-5]|2[0-4]\\d|[01]?\\d\\d?)\\b"
                }
            ]
        },
        "mac_address": {
            "comment": "MAC addresses (e.g. 00e0-fc00-0000)",
            "patterns": [
                {
                    "name": "constant.numeric.mac.vrp",
                    "match": "\\b[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}\\b"
                }
            ]
        },
        "number_constant": {
            "comment": "Standalone numbers: AS numbers, VLANs, indices, etc.",
            "patterns": [
                {
                    "name": "constant.numeric.integer.vrp",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        "string_quoted": {
            "comment": "Quoted description strings",
            "patterns": [
                {
                    "name": "string.quoted.double.vrp",
                    "match": "\"[^\"]*\""
                }
            ]
        }
    },
    "scopeName": "source.vrp"
}